{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DFtool",
  "version": "0.1.0",
  "identifier": "com.dftool.mapmarker",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "control",
        "title": "DFtool 控制台",
        "width": 420,
        "height": 680,
        "resizable": true,
        "fullscreen": false,
        "transparent": false,
        "decorations": true
      },
      {
        "label": "overlay",
        "title": "DFtool Overlay",
        "fullscreen": true,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["../config", "../assets"],
    "icon": ["icons/icon.ico"]
  }
}
